---
import '../global.css'
import StandardHead from '../components/standard-head.astro'
import StandaloneSandboxPlayer from '../components/big-interactive-pages/standalone-sandbox-player'

const file = Astro.url.searchParams.get('file') ?? ''
const codeRes = await fetch(file)
const code = await codeRes.text()
const watchMs = Astro.url.searchParams.has('watch')
	? Number(Astro.url.searchParams.get('watch') || 1000)
	: undefined
---

<html lang='en'>
	<head>
		<StandardHead title='(Deprecated) File Player' />
		<style>
			#screen-container {
				width: 100%;
				height: 100%;
				display: flex;
				justify-content: center;
				align-items: center;
			}

			.screen {
				max-width: 100%;
				max-height: 100%;
				background: black;
			}
		</style>
	</head>
	<body>
		<div id='screen-container'>
			<StandaloneSandboxPlayer
				client:load
				code={code}
				watchFile={watchMs ? file : undefined}
				watchMs={watchMs}
				class="screen"
			/>
		</div>
	</body>
</html>
